# Create a Discord app at https://discord.com/developers/applications
# Copy the Application ID here
DISCORD_CLIENT_ID=your_application_id_here

# How many minutes of inactivity before the daemon exits (default 30)
# IDLE_TIMEOUT_MINUTES=30

# Change the hook server port if 6463 is taken
# RPC_PORT=7463

# Verbose hook logging
# DEBUG=1
